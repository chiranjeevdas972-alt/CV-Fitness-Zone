rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isBypassUser() {
      return isSignedIn() && (
        request.auth.uid == "u6wzcrXtnFTQlJWLxyaZL4JR1pn2" ||
        (request.auth.token != null && "email" in request.auth.token && request.auth.token.email == "chiranjeevdas972@gmail.com")
      );
    }

    function isVerifiedUser() {
      return isSignedIn() && (
        isBypassUser() ||
        (request.auth.token != null && "email_verified" in request.auth.token && request.auth.token.email_verified == true)
      );
    }

    function hasRole(role) {
      return hasUserDoc() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == role;
    }

    function hasGymId(gymId) {
      return hasUserDoc() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('gymId', '') == gymId;
    }

    function isAdmin() {
      return isSignedIn() && (
        isBypassUser() ||
        hasRole("admin") ||
        hasRole("manager")
      );
    }

    function isTrainer() {
      return isSignedIn() && (
        isBypassUser() ||
        hasRole("trainer") ||
        hasRole("admin") ||
        hasRole("manager")
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isBypassUser() ||
        hasRole("staff") ||
        hasRole("trainer") ||
        hasRole("manager") ||
        hasRole("admin")
      );
    }

    function sameGym(gymId) {
      return isSignedIn() && (
        isBypassUser() ||
        hasGymId(gymId)
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data != null &&
             data.get('uid', '') == request.auth.uid &&
             data.get('role', '') is string &&
             data.get('gymId', '') is string &&
             data.get('gymId', '').size() > 0;
    }

    function isValidMember(data) {
      return data != null &&
             data.get('name', '') is string && data.get('name', '').size() > 0 &&
             data.get('gymId', '') is string && data.get('gymId', '').size() > 0;
    }

    function isValidAnnouncement(data) {
      return data != null &&
             data.get('title', '') is string && data.get('title', '').size() > 0 &&
             data.get('gymId', '') is string && data.get('gymId', '').size() > 0;
    }

    // --- Rules ---

    match /users/{uid} {
      allow read, write: if isBypassUser();
      allow get, write: if isOwner(uid);
      allow list: if isAdmin();
    }

    match /members/{memberId} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow create: if isVerifiedUser() && (isAdmin() || isTrainer()) && isValidMember(request.resource.data);
      allow update: if isVerifiedUser() && (isAdmin() || isTrainer()) && isValidMember(request.resource.data) && 
                    request.resource.data.get('gymId', '') == resource.data.get('gymId', '');
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /trainers/{trainerId} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow write: if isVerifiedUser() && isAdmin();
    }

    match /plans/{planId} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow write: if isVerifiedUser() && isAdmin();
    }

    match /payments/{paymentId} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow write: if isVerifiedUser() && (isAdmin() || isTrainer());
    }

    match /attendance/{attendanceId} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow create, update: if isVerifiedUser() && (isAdmin() || isTrainer());
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /batches/{batchId} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow write: if isVerifiedUser() && isAdmin();
    }

    match /settings/{gymId} {
      allow read, write: if isBypassUser();
      allow get: if isSignedIn();
      allow write: if isVerifiedUser() && isAdmin();
    }

    match /announcements/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow create, update: if isVerifiedUser() && (isAdmin() || isTrainer()) && isValidAnnouncement(request.resource.data);
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /inventory/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow create, update: if isVerifiedUser() && isAdmin() && (id is string && id.size() > 0);
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isBypassUser() || isAdmin() || isStaff();
    }

    // Interactive/Auxiliary collections
    match /assigned_workouts/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isAdmin() || isTrainer() || (resource != null && sameGym(resource.data.get('gymId', '')));
      allow create, update: if isVerifiedUser() && (isAdmin() || isTrainer());
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /classes/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow create, update: if isVerifiedUser() && (isAdmin() || isTrainer());
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /workout_templates/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isSignedIn();
      allow create, update: if isVerifiedUser() && (isAdmin() || isTrainer());
      allow delete: if isVerifiedUser() && isAdmin();
    }

    match /crmLeads/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isAdmin() || isStaff();
      allow create, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /crmFollowups/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isAdmin() || isStaff();
      allow create, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /crmActivities/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isAdmin() || isStaff();
      allow create, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /memberRetention/{id} {
      allow read, write: if isBypassUser();
      allow get, list: if isAdmin() || isStaff();
      allow create, update: if isAdmin() || isStaff();
      allow delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read, write: if isBypassUser() || isSignedIn();
    }

    match /contactMessages/{id} {
      allow read, write: if isBypassUser() || isAdmin() || isStaff() || true;
    }
  }
}
